rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData(request.auth.uid).role == role;
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Listings
    match /listings/{listingId} {
      allow read: if true; // Everyone can see listings
      allow create: if isSignedIn() && (hasRole('owner') || hasRole('admin'));
      allow update, delete: if isSignedIn() && (isOwner(resource.data.ownerId) || hasRole('admin'));
    }

    // Inquiries
    match /inquiries/{inquiryId} {
      allow read: if isSignedIn() && (isOwner(resource.data.tenantId) || isOwner(resource.data.ownerId) || hasRole('admin'));
      allow create: if isSignedIn() && hasRole('tenant');
      allow update, delete: if isSignedIn() && (isOwner(resource.data.ownerId) || hasRole('admin'));
    }
  }
}
