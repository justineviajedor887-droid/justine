{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account details and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["tenant", "owner", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Listing": {
      "title": "Property Listing",
      "description": "Details of a property for rent or sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "address": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "images": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["available", "rented", "pending"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "title", "price", "status"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A message from a tenant to an owner about a listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "tenantId": { "type": "string" },
        "ownerId": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "replied"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["listingId", "tenantId", "ownerId", "message"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "listings/{listingId}": {
      "schema": "Listing",
      "description": "Property listings"
    },
    "inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Tenant inquiries on properties"
    }
  }
}
